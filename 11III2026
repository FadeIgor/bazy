1. unikalne miasta klientow
SELECT DISTINCT klienci.miasto FROM klienci;

2. produkty w cenie 100 -1000zl 
SELECT * FROM produkty
where produkty.cena BETWEEN 100 AND 1000;

3. klienci z miast na w
SELECT * FROM klienci WHERE klienci.miasto LIKE "W%";

4. zamowienia klientow 1 i 2
SELECT * FROM zamowienia WHERE id_klienta IN (1, 2);
SELECT * FROM zamowienia WHERE id_klienta  = 1 or id_klienta = 2;

5. klienci nie mieszkaja w wwa
SELECT * FROM klienci WHERE klienci.miasto != 'Warszawa';

6. nazwy kategorii zawierajace o w nazwie
SELECT * FROM kategorie WHERE nazwa LIKE "%o%";

7. zamowienai miedzy 1.01 an 28.02
SELECT * FROM zamowienia WHERE data_zamowienia BETWEEN '2024-01-01' AND '2024-02-28';

8. pozycja 1+
SELECT * FROM zamowienia WHERE EXISTS( SELECT 1 FROM pozycjezamowienia WHERE pozycjezamowienia.id_zamowienia = zamowienia.id_zamowienia);

9. zamowienia w lutym lub marcu 2025
SELECT * FROM zamowienia WHERE data_zamowienia BETWEEN '2024-02-01' and '2024-03-31';

10. produkty zamowione w ilosci 1-3
SELECT * FROM produkty WHERE produkty.id_produktu IN(
  	SELECT id_produktu FROM pozycjezamowienia WHERE ilosc BETWEEN 1 AND 3  
);

11. produkty zamowione wiecej niz 1 raz
SELECT * FROM produkty WHERE produkty.id_produktu IN(
  	SELECT id_produktu FROM pozycjezamowienia WHERE ilosc > 1  
);

